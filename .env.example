# =============================================================================
# Inventory QAS - Variables de entorno (Plan v3.0 - Anexo A)
# Copiar a .env y ajustar valores locales. Nunca commitear .env real.
#
# Compose:
#   dev:     docker compose -f docker-compose.dev.yml
#   test:    docker compose -f docker-compose.dev.yml -f docker-compose.test.yml
#   staging: + docker-compose.observability.yml + docker-compose.staging.yml
# =============================================================================

# --- Perfil general ---
COMPOSE_PROJECT_NAME=inventory-qas
SPRING_PROFILES_ACTIVE=dev,observability

# --- PostgreSQL ---
POSTGRES_DB=inventory
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_password
DATABASE_URL=jdbc:postgresql://postgres:5432/inventory
DATABASE_USERNAME=inventory_user
DATABASE_PASSWORD=inventory_password

# --- Keycloak (host: puerto 8081; red Docker: keycloak:8080) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Docker Compose fija issuer localhost:8081 (debe coincidir con claim iss del JWT)
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/inventory-realm
KEYCLOAK_JWKS_URI=http://host.docker.internal:8081/realms/inventory-realm/protocol/openid-connect/certs
# Local sin Docker (backend en IDE)
KEYCLOAK_ISSUER_URI_HOST=http://localhost:8081/realms/inventory-realm
KEYCLOAK_JWKS_URI_HOST=http://localhost:8081/realms/inventory-realm/protocol/openid-connect/certs

# --- Backend API ---
SERVER_PORT=8080
OTEL_SERVICE_NAME=inventory-api
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://alloy:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://alloy:4318/v1/metrics
OTEL_TRACES_SAMPLER_PROBABILITY=1.0

# --- CORS (backend) ---
INVENTORY_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_KEYCLOAK_URL=/keycloak
NEXT_PUBLIC_KEYCLOAK_REALM=inventory-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=inventory-frontend
# Solo si ejecutas `npm run dev` FUERA de Docker (en el host):
API_PROXY_TARGET=http://localhost:8080
KEYCLOAK_PROXY_TARGET=http://localhost:8081
# Docker Compose ignora lo anterior y usa backend:8080 / keycloak:8080 en la red interna.

# --- Observabilidad (staging - Fase 5+) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=7d

# --- SonarQube (staging - Fase 6+) ---
SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=replace_with_local_token

# --- Jenkins (staging - Fase 6+) ---
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin
