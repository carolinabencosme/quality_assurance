# =============================================================================
# Inventory QAS - Variables de entorno (Plan v3.0 - Anexo A)
# =============================================================================
# Uso: copy .env.example .env  (Windows: copy .env.example .env)
# .env no se versiona — ver README y .gitignore
# Valores de ejemplo solo para desarrollo local / académico. Nunca commitear .env real.
# =============================================================================

# --- Perfil Spring ---
SPRING_PROFILES_ACTIVE=dev
# Compose (no en Anexo A; nombre del proyecto Docker en local)
COMPOSE_PROJECT_NAME=inventory-qas

# --- PostgreSQL ---
# POSTGRES_* = imagen postgres en Docker Compose
POSTGRES_DB=inventory
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_password
# DATABASE_* = JDBC Spring Boot (backend)
DATABASE_URL=jdbc:postgresql://postgres:5432/inventory
DATABASE_USERNAME=inventory_user
DATABASE_PASSWORD=inventory_password

# --- Keycloak ---
# Admin console (contenedor keycloak)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Resource Server: red Docker (hostname keycloak:8080 dentro de Compose)
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/inventory-realm
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/inventory-realm/protocol/openid-connect/certs
# Opcional: desarrollo fuera de Docker (IDE / tests en host)
KEYCLOAK_ISSUER_URI_HOST=http://localhost:8081/realms/inventory-realm
KEYCLOAK_JWKS_URI_HOST=http://localhost:8081/realms/inventory-realm/protocol/openid-connect/certs

# --- OpenTelemetry (Fase 5+; Alloy en staging) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
OTEL_SERVICE_NAME=inventory-api

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8080/api/v1
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=inventory-realm
VITE_KEYCLOAK_CLIENT_ID=inventory-frontend

# --- Backend API (puerto publicado en host) ---
SERVER_PORT=8080

# --- Observabilidad / Grafana stack (staging - Fase 5+) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=7d

# --- SonarQube (staging / CI - Fase 6+) ---
SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=replace_with_local_token
# SONAR_PROJECT_KEY=inventory-qas

# --- Jenkins (staging - Fase 6+) ---
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin
