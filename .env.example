# =============================================================================
# Inventory QAS - Variables de entorno (Plan v3.0 - Anexo A)
# Uso: copy .env.example .env  (Windows: copy .env.example .env)
# .env no se versiona — ver README y .gitignore
# Valores de ejemplo solo para desarrollo local / académico. Nunca commitear .env real.
#
# Compose:
#   dev:     docker compose -f docker-compose.dev.yml
#   test:    docker compose -f docker-compose.dev.yml -f docker-compose.test.yml
#   staging: + docker-compose.observability.yml + docker-compose.staging.yml
# =============================================================================

# --- Perfil Spring / Docker ---
SPRING_PROFILES_ACTIVE=dev,observability
COMPOSE_PROJECT_NAME=inventory-qas

# --- PostgreSQL ---
# POSTGRES_* = imagen postgres en Docker Compose
POSTGRES_DB=inventory
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_password
# DATABASE_* = JDBC Spring Boot (backend)
DATABASE_URL=jdbc:postgresql://postgres:5432/inventory
DATABASE_USERNAME=inventory_user
DATABASE_PASSWORD=inventory_password

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Docker Compose: issuer localhost:8081 (debe coincidir con claim iss del JWT en el navegador)
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/inventory-realm
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/inventory-realm/protocol/openid-connect/certs
# Desarrollo fuera de Docker (IDE / tests en host)
KEYCLOAK_ISSUER_URI_HOST=http://localhost:8081/realms/inventory-realm
KEYCLOAK_JWKS_URI_HOST=http://localhost:8081/realms/inventory-realm/protocol/openid-connect/certs
KEYCLOAK_REALM=inventory-realm
KEYCLOAK_ADMIN_URL=http://keycloak:8080
KEYCLOAK_ADMIN_CLIENT_ID=inventory-admin-api
# Solo desarrollo/test. En produccion usar un secreto distinto y ejecutar el script de rotacion.
KEYCLOAK_ADMIN_CLIENT_SECRET=inventory-admin-secret-change-me

# --- Backend API ---
SERVER_PORT=8080

# --- OpenTelemetry (Fase 5+) ---
OTEL_SERVICE_NAME=inventory-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://alloy:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://alloy:4318/v1/metrics
OTEL_TRACES_SAMPLER_PROBABILITY=1.0

# --- CORS (backend) ---
INVENTORY_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8081
NEXT_PUBLIC_KEYCLOAK_REALM=inventory-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=inventory-frontend
NEXT_PUBLIC_KEYCLOAK_API_CLIENT_ID=inventory-api
# Origen público de la app (OIDC redirect_uri = {APP_URL}/auth/callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Solo si ejecutas `npm run dev` FUERA de Docker (en el host):
API_PROXY_TARGET=http://localhost:8080
KEYCLOAK_PROXY_TARGET=http://keycloak:8080

# --- Observabilidad / Grafana stack (staging - Fase 5+) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=7d

# --- SonarQube (staging / CI - Fase 6+) ---
SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=replace_with_local_token

# --- Jenkins (staging - Fase 6+) ---
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin

# --- Local production demo ---
# Change these before any real deployment.
KC_HOSTNAME=http://localhost:8081
POSTGRES_PROD_PASSWORD=replace_with_local_prod_password
KEYCLOAK_ADMIN_PROD_PASSWORD=replace_with_local_prod_admin_password

# --- Security scans ---
ZAP_TARGET=http://host.docker.internal:3000
SCHEMATHESIS_SCHEMA_URL=http://host.docker.internal:8080/v3/api-docs

# --- k6 performance ---
BASE_URL=http://localhost:8080
KEYCLOAK_URL=http://localhost:8081
K6_USERNAME=viewer
K6_PASSWORD=replace_with_local_viewer_password
RUN_K6_SMOKE=false
