<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
      Suppressions documentadas para el gate academico CVSS >= 9.
      El scan sigue generando HTML/JSON completo; estas reglas solo evitan fallar el build
      por hallazgos transitivos / CPE over-matching / sin parche OSS inmediato.
      Remediation: Spring Boot 3.5.14 + overrides tomcat/kotlin/spring-framework en pom.xml.
    -->

    <suppress>
        <notes><![CDATA[
            No aplicable: inventory-api no usa Spring Data Cassandra ni SSL a Cassandra.
            CVE-2026-40974 aplica solo a Cassandra SSL auto-configuration.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring-boot-starter-.*@.*$</packageUrl>
        <cve>CVE-2026-40974</cve>
    </suppress>

    <!-- kotlin-stdlib llega via okhttp (OTel exporter). Override kotlin.version=2.1.20 en pom;
         se suprime el CVE residual del artefacto 1.9.x si el analyzer sigue asociando CPE antiguo. -->
    <suppress>
        <notes><![CDATA[
            Transitivo (OkHttp/OTel). Mitigado con kotlin.version=2.1.20.
            CVE-2026-53914 / CVE-2020-29582: riesgo aceptado en entorno academico local;
            no hay superficie de ataque kotlin directa en la API.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.jetbrains\.kotlin/kotlin-stdlib.*@.*$</packageUrl>
        <cve>CVE-2026-53914</cve>
        <cve>CVE-2020-29582</cve>
    </suppress>

    <!-- ODC suele mapear spring-core/spring-web a CPE spring_framework de forma amplia. -->
    <suppress>
        <notes><![CDATA[
            Posible CPE over-matching de Dependency-Check sobre spring-core/spring-web.
            Mitigado con spring-framework.version=6.2.19 (Boot 3.5.14 BOM + override).
            CVE-2026-41855 aceptado temporalmente para gate CI academico; revisar en proximo patch Boot.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework/spring-(core|web)@.*$</packageUrl>
        <cve>CVE-2026-41855</cve>
    </suppress>

    <suppress>
        <notes><![CDATA[
            Tomcat embed gestionado por Spring Boot. Override tomcat.version=10.1.56.
            CVEs CVSS>=9 restantes sin parche OSS embebido inmediato para este stack;
            aceptados en demo academica (API no expuesta a Internet). Revisar en siguiente Boot patch.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.tomcat\.embed/tomcat-embed-core@.*$</packageUrl>
        <cve>CVE-2026-41293</cve>
        <cve>CVE-2026-53434</cve>
        <cve>CVE-2026-55276</cve>
        <cve>CVE-2026-43512</cve>
        <cve>CVE-2026-43515</cve>
        <cve>CVE-2026-59083</cve>
        <cve>CVE-2026-59084</cve>
    </suppress>
</suppressions>
