COMPOSE_PROJECT_NAME=inventory-qas-prod

POSTGRES_DB=inventory
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=SET_IN_ENV_POSTGRES_PASSWORD

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=SET_IN_ENV_KEYCLOAK_ADMIN_PASSWORD
KC_HOSTNAME=http://localhost:8081

DATABASE_URL=jdbc:postgresql://postgres:5432/inventory
DATABASE_USERNAME=inventory_user
DATABASE_PASSWORD=SET_IN_ENV_POSTGRES_PASSWORD

KEYCLOAK_REALM=inventory-realm
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/inventory-realm
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/inventory-realm/protocol/openid-connect/certs
KEYCLOAK_ADMIN_URL=http://keycloak:8080
KEYCLOAK_ADMIN_CLIENT_ID=inventory-admin-api
KEYCLOAK_ADMIN_CLIENT_SECRET=SET_IN_ENV_KEYCLOAK_ADMIN_CLIENT_SECRET

INVENTORY_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SPRING_PROFILES_ACTIVE=prod,observability
SERVER_PORT=8080

NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8081
NEXT_PUBLIC_KEYCLOAK_REALM=inventory-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=inventory-frontend
NEXT_PUBLIC_KEYCLOAK_API_CLIENT_ID=inventory-api
NEXT_PUBLIC_APP_URL=http://localhost:3000

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=SET_IN_ENV_GRAFANA_ADMIN_PASSWORD

OTEL_SERVICE_NAME=inventory-api
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://alloy:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://alloy:4318/v1/metrics
OTEL_TRACES_SAMPLER_PROBABILITY=1.0
