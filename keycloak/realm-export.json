{
  "realm": "inventory-realm",
  "enabled": true,
  "displayName": "Inventory QAS",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "inventory-admin",
        "description": "Administrador — todos los permisos del API",
        "composite": true,
        "composites": {
          "client": {
            "inventory-backend": [
              "product:view",
              "product:manage",
              "stock:view",
              "stock:manage",
              "report:view",
              "audit:view",
              "user:manage"
            ]
          }
        }
      },
      {
        "name": "warehouse-manager",
        "description": "Gestión operativa de inventario",
        "composite": true,
        "composites": {
          "client": {
            "inventory-backend": [
              "product:view",
              "product:manage",
              "stock:view",
              "stock:manage",
              "report:view"
            ]
          }
        }
      },
      {
        "name": "inventory-clerk",
        "description": "Registro de entradas y salidas",
        "composite": true,
        "composites": {
          "client": {
            "inventory-backend": [
              "product:view",
              "stock:view",
              "stock:manage"
            ]
          }
        }
      },
      {
        "name": "inventory-viewer",
        "description": "Solo lectura de productos y stock",
        "composite": true,
        "composites": {
          "client": {
            "inventory-backend": [
              "product:view",
              "stock:view",
              "report:view"
            ]
          }
        }
      }
    ],
    "client": {
      "inventory-backend": [
        {
          "name": "product:view",
          "description": "Ver productos y categorías",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "product:manage",
          "description": "Crear, editar e inactivar productos",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "stock:view",
          "description": "Ver existencias e historial",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "stock:manage",
          "description": "Registrar entradas, salidas y ajustes",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "report:view",
          "description": "Ver reportes y dashboard",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "audit:view",
          "description": "Consultar auditoría",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "user:manage",
          "description": "Gestionar usuarios y permisos",
          "composite": false,
          "clientRole": true
        }
      ]
    }
  },
  "clients": [
    {
      "clientId": "inventory-frontend",
      "name": "Inventory Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "+"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "email"
      ]
    },
    {
      "clientId": "inventory-backend",
      "name": "Inventory Backend API",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "users": [
