{
  "realm": "inventory-realm",
  "enabled": true,
  "displayName": "Cub",
  "displayNameHtml": "Cub",
  "loginTheme": "cub",
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "es"],
  "defaultLocale": "es",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "inventory-admin",
        "description": "Administrador — todos los permisos del API",
        "composite": true,
        "composites": {
          "client": {
            "inventory-api": [
              "product:view",
              "product:manage",
              "stock:view",
              "stock:manage",
              "report:view",
              "audit:view",
              "user:manage"
            ]
          }
        }
      },
      {
        "name": "warehouse-manager",
        "description": "Gestión operativa de inventario",
        "composite": true,
        "composites": {
          "client": {
            "inventory-api": [
              "product:view",
              "product:manage",
              "stock:view",
              "stock:manage",
              "report:view"
            ]
          }
        }
      },
      {
        "name": "inventory-clerk",
        "description": "Registro de entradas y salidas",
        "composite": true,
        "composites": {
          "client": {
            "inventory-api": [
              "product:view",
              "stock:view",
              "stock:manage"
            ]
          }
        }
      },
      {
        "name": "inventory-viewer",
        "description": "Solo lectura de productos, stock y reportes",
        "composite": true,
        "composites": {
          "client": {
            "inventory-api": [
              "product:view",
              "stock:view",
              "report:view"
            ]
          }
        }
      }
    ],
    "client": {
      "inventory-api": [
        {
          "name": "product:view",
          "description": "Ver productos y categorías",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "product:manage",
          "description": "Crear, editar e inactivar productos",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "stock:view",
          "description": "Ver existencias e historial",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "stock:manage",
          "description": "Registrar entradas, salidas y ajustes",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "report:view",
          "description": "Ver reportes y dashboard",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "audit:view",
          "description": "Consultar auditoría Envers",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "user:manage",
          "description": "Gestionar usuarios y permisos en Keycloak",
          "composite": false,
          "clientRole": true
        }
      ]
    }
  },
  "clientScopes": [
    {
      "name": "product:view",
      "description": "Ver productos",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "product:manage",
      "description": "Gestionar productos",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "stock:view",
      "description": "Ver stock",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "stock:manage",
      "description": "Gestionar movimientos",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "report:view",
      "description": "Ver reportes y dashboard",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "user:manage",
      "description": "Gestionar usuarios",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "audit:view",
      "description": "Ver auditoria",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "clients": [
    {
      "clientId": "inventory-frontend",
      "name": "Inventory Frontend",
      "description": "Cliente público SPA (Next.js) — Authorization Code + PKCE",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "redirectUris": [
        "http://localhost:3000/auth/callback",
        "http://127.0.0.1:3000/auth/callback",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:3002/*",
        "http://127.0.0.1:3002/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "http://localhost:3002",
        "http://127.0.0.1:3002",
        "+"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "openid",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt",
        "product:view",
        "product:manage",
        "stock:view",
        "stock:manage",
        "report:view",
        "user:manage",
        "audit:view"
      ]
    },
    {
      "clientId": "inventory-api",
      "name": "Inventory API",
      "description": "Resource Server (Spring Boot) — validación JWT bearer-only",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "authorizationServicesEnabled": true,
      "authorizationSettings": {
        "allowRemoteResourceManagement": true,
        "policyEnforcementMode": "ENFORCING",
        "decisionStrategy": "UNANIMOUS",
        "resources": [
          {
            "name": "Products",
            "type": "urn:inventory:resources:products",
            "ownerManagedAccess": false,
            "uris": ["/api/v1/products/*"],
            "scopes": [
              { "name": "product:view" },
              { "name": "product:manage" }
            ]
          },
          {
            "name": "Stock",
            "type": "urn:inventory:resources:stock",
            "ownerManagedAccess": false,
            "uris": ["/api/v1/stock/*"],
            "scopes": [
              { "name": "stock:view" },
              { "name": "stock:manage" }
            ]
          },
          {
            "name": "Reports",
            "type": "urn:inventory:resources:reports",
            "ownerManagedAccess": false,
            "uris": ["/api/v1/reports/*"],
            "scopes": [
              { "name": "report:view" }
            ]
          },
          {
            "name": "Users",
            "type": "urn:inventory:resources:users",
            "ownerManagedAccess": false,
            "uris": ["/api/v1/users/*"],
            "scopes": [
              { "name": "user:manage" }
            ]
          },
          {
            "name": "Audit",
            "type": "urn:inventory:resources:audit",
            "ownerManagedAccess": false,
            "uris": ["/api/v1/audit/*"],
            "scopes": [
              { "name": "audit:view" }
            ]
          }
        ],
        "scopes": [
          { "name": "product:view", "displayName": "Ver productos" },
          { "name": "product:manage", "displayName": "Gestionar productos" },
          { "name": "stock:view", "displayName": "Ver stock" },
          { "name": "stock:manage", "displayName": "Gestionar movimientos" },
          { "name": "report:view", "displayName": "Ver reportes" },
          { "name": "user:manage", "displayName": "Gestionar usuarios" },
          { "name": "audit:view", "displayName": "Ver auditoria" }
        ],
        "policies": [
          {
            "name": "admin-policy",
            "description": "inventory-admin puede usar todos los scopes",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "roles": "[{\"id\":\"inventory-admin\",\"required\":true}]"
            }
          },
          {
            "name": "warehouse-policy",
            "description": "warehouse-manager gestiona producto, stock y reportes",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "roles": "[{\"id\":\"warehouse-manager\",\"required\":true}]"
            }
          },
          {
            "name": "clerk-policy",
            "description": "inventory-clerk ve producto y gestiona stock",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "roles": "[{\"id\":\"inventory-clerk\",\"required\":true}]"
            }
          },
          {
            "name": "viewer-policy",
            "description": "inventory-viewer tiene lectura operativa",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "roles": "[{\"id\":\"inventory-viewer\",\"required\":true}]"
            }
          }
        ],
        "permissions": [
          {
            "name": "admin-all-scopes-permission",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"Products\",\"Stock\",\"Reports\",\"Users\",\"Audit\"]",
              "scopes": "[\"product:view\",\"product:manage\",\"stock:view\",\"stock:manage\",\"report:view\",\"user:manage\",\"audit:view\"]",
              "applyPolicies": "[\"admin-policy\"]"
            }
          },
          {
            "name": "warehouse-products-stock-reports-permission",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"Products\",\"Stock\",\"Reports\"]",
              "scopes": "[\"product:view\",\"product:manage\",\"stock:view\",\"stock:manage\",\"report:view\"]",
              "applyPolicies": "[\"warehouse-policy\"]"
            }
          },
          {
            "name": "clerk-products-stock-permission",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"Products\",\"Stock\"]",
              "scopes": "[\"product:view\",\"stock:view\",\"stock:manage\"]",
              "applyPolicies": "[\"clerk-policy\"]"
            }
          },
          {
            "name": "viewer-read-permission",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"Products\",\"Stock\",\"Reports\"]",
              "scopes": "[\"product:view\",\"stock:view\",\"report:view\"]",
              "applyPolicies": "[\"viewer-policy\"]"
            }
          }
        ]
      }
    },
    {
      "clientId": "inventory-admin-api",
      "name": "Inventory Admin API",
      "description": "Cliente confidencial para gestion real de usuarios via Keycloak Admin API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": false,
      "secret": "${KEYCLOAK_ADMIN_CLIENT_SECRET}"
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@inventory.local",
      "firstName": "Admin",
      "lastName": "Inventory",
      "emailVerified": true,
      "realmRoles": ["inventory-admin"],
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ]
    },
    {
      "username": "warehouse",
      "enabled": true,
      "email": "warehouse@inventory.local",
      "firstName": "Warehouse",
      "lastName": "Manager",
      "emailVerified": true,
      "realmRoles": ["warehouse-manager"],
      "credentials": [
        {
          "type": "password",
          "value": "warehouse123",
          "temporary": false
        }
      ]
    },
    {
      "username": "clerk",
      "enabled": true,
      "email": "clerk@inventory.local",
      "firstName": "Inventory",
      "lastName": "Clerk",
      "emailVerified": true,
      "realmRoles": ["inventory-clerk"],
      "credentials": [
        {
          "type": "password",
          "value": "clerk123",
          "temporary": false
        }
      ]
    },
    {
      "username": "viewer",
      "enabled": true,
      "email": "viewer@inventory.local",
      "firstName": "Read",
      "lastName": "Only",
      "emailVerified": true,
      "realmRoles": ["inventory-viewer"],
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ]
    },
    {
      "username": "service-account-inventory-admin-api",
      "enabled": true,
      "serviceAccountClientId": "inventory-admin-api",
      "clientRoles": {
        "realm-management": [
          "view-users",
          "manage-users",
          "view-realm",
          "manage-realm"
        ]
      }
    }
  ]
}
